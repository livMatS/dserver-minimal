# Build-time configuration baked into the static dtool-lookup-webapp bundle.
# Vue CLI inlines VUE_APP_* variables at `npm run build` time.

# The webapp talks to dserver through nginx on the published port, under /lookup.
VUE_APP_DTOOL_LOOKUP_SERVER_URL=http://localhost:8888/lookup

# This image runs dserver with DISABLE_JWT_AUTHORISATION=True, so the webapp must
# skip the sign-in screen and issue unauthenticated requests. Flipping this to
# "true" without also enabling auth in dserver produces 401s from the API.
VUE_APP_AUTH_ENABLED=false
VUE_APP_OAUTH2_ENABLED=false
VUE_APP_SHOW_USERNAME_PASSWORD_FORM=false
